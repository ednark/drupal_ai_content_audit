{#
/**
 * @file
 * AI Score tab content for the AIRO panel.
 *
 * Variables:
 * - score: Overall score (0-100).
 * - qualitative_label: 'Needs Work', 'Improving', or 'AI Ready'.
 * - score_color: 'good', 'warning', or 'danger'.
 * - score_color_hex: Hex color for the donut stroke.
 * - trend_delta: Integer point change from previous assessment (can be negative).
 * - donut_radius: SVG circle radius (50).
 * - donut_circumference: Calculated circumference.
 * - donut_offset: Calculated stroke-dashoffset.
 * - sub_scores: Array of {dimension, label, score, max_score, percentage}.
 * - checkpoints: Array of {category, item, status, priority}.
 * - checkpoints_by_category: Checkpoints grouped by category.
 * - history: Array of {date, score, bar_height}.
 * - node_id: The node ID.
 * - assess_url: URL for the re-analyze endpoint.
 */
#}
<div class="airo-score" data-node-id="{{ node_id }}">

  {# Section 1: Overall Score #}
  <div class="airo-score__overview">
    <div class="airo-score__donut-container">
      <svg viewBox="0 0 128 128" class="airo-score__donut-svg">
        <circle class="airo-score__donut-bg"
          cx="64" cy="64" r="{{ donut_radius }}"
          fill="none" stroke="#e5e7eb" stroke-width="10" />
        <circle class="airo-score__donut-fill"
          cx="64" cy="64" r="{{ donut_radius }}"
          fill="none"
          stroke="{{ score_color_hex }}"
          stroke-width="10"
          stroke-dasharray="{{ donut_circumference }}"
          stroke-dashoffset="{{ donut_offset }}"
          stroke-linecap="round"
          transform="rotate(-90 64 64)" />
        <text x="64" y="58" text-anchor="middle" dominant-baseline="central"
          class="airo-score__donut-score">{{ score }}</text>
        <text x="64" y="78" text-anchor="middle" dominant-baseline="central"
          class="airo-score__donut-label">{{ qualitative_label }}</text>
      </svg>
    </div>
    <div class="airo-score__overview-info">
      {% if trend_delta is not null %}
        <div class="airo-score__trend airo-score__trend--{{ trend_delta >= 0 ? 'up' : 'down' }}">
          {% if trend_delta >= 0 %}
            <span class="airo-score__trend-arrow">↑</span>
            <span>+{{ trend_delta }} {{ 'points since last check'|t }}</span>
          {% else %}
            <span class="airo-score__trend-arrow">↓</span>
            <span>{{ trend_delta }} {{ 'points since last check'|t }}</span>
          {% endif %}
        </div>
      {% endif %}
      <button type="button" class="airo-score__reanalyze button button--primary button--small"
        data-assess-url="{{ assess_url }}">
        {{ 'Re-analyze'|t }}
      </button>
    </div>
  </div>

  {# Section 2: Sub-Score Breakdown #}
  {% if sub_scores is not empty %}
  <div class="airo-score__breakdown">
    <h3 class="airo-score__section-title">{{ 'Score Breakdown'|t }}</h3>
    {% for sub in sub_scores %}
      <div class="airo-score__subscore">
        <div class="airo-score__subscore-header">
          <span class="airo-score__subscore-label">{{ sub.label }}</span>
          <span class="airo-score__subscore-value">{{ sub.score }}/{{ sub.max_score }}</span>
        </div>
        <div class="airo-score__subscore-bar">
          <div class="airo-score__subscore-fill" style="width: {{ sub.percentage }}%; background-color: {{ sub.color|default('#3b82f6') }};"></div>
        </div>
      </div>
    {% endfor %}
  </div>
  {% endif %}

  {# Section 3: Detailed Checkpoints #}
  {% if checkpoints_by_category is not empty %}
  <div class="airo-score__checkpoints">
    <h3 class="airo-score__section-title">{{ 'Detailed Checkpoints'|t }}</h3>
    {% for category, items in checkpoints_by_category %}
      <div class="airo-score__checkpoint-group">
        <h4 class="airo-score__checkpoint-category">{{ category }}</h4>
        <table class="airo-score__checkpoint-table">
          <tbody>
            {% for checkpoint in items %}
              <tr class="airo-score__checkpoint-row airo-score__checkpoint-row--{{ checkpoint.status }}">
                <td class="airo-score__checkpoint-icon">
                  {% if checkpoint.status == 'pass' %}
                    <span class="airo-score__icon airo-score__icon--pass" title="{{ 'Pass'|t }}">✓</span>
                  {% elseif checkpoint.status == 'fail' %}
                    <span class="airo-score__icon airo-score__icon--fail" title="{{ 'Fail'|t }}">✗</span>
                  {% else %}
                    <span class="airo-score__icon airo-score__icon--warning" title="{{ 'Warning'|t }}">⚠</span>
                  {% endif %}
                </td>
                <td class="airo-score__checkpoint-item">{{ checkpoint.item }}</td>
                <td class="airo-score__checkpoint-priority">
                  <span class="airo-score__priority-badge airo-score__priority-badge--{{ checkpoint.priority }}">
                    {{ checkpoint.priority }}
                  </span>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endfor %}
  </div>
  {% endif %}

  {# Section 4: Historical Trend #}
  {% if history is not empty %}
  <div class="airo-score__history">
    <h3 class="airo-score__section-title">{{ 'Score History'|t }}</h3>
    <div class="airo-score__history-chart">
      {% for entry in history %}
        <div class="airo-score__history-bar-wrapper">
          <div class="airo-score__history-bar" style="height: {{ entry.bar_height }}%;"
            title="{{ entry.date }}: {{ entry.score }}">
            <span class="airo-score__history-value">{{ entry.score }}</span>
          </div>
          <span class="airo-score__history-date">{{ entry.date_short }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# No data fallback #}
  {% if score is null %}
  <div class="airo-score__empty">
    <p>{{ 'No assessment data available. Run an analysis to see your AI readiness score.'|t }}</p>
  </div>
  {% endif %}

</div>
